{
  "name": "@kimenzo/bento-mcp",
  "mcpName": "io.github.kimenzo/bento-mcp",
  "keywords": [
    "bento",
    "aetherix",
    "anytype",
    "api",
    "mcp",
    "server"
  ],
  "version": "1.2.5",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:dev": "vitest watch",
    "build": "node -e \"require('fs').rmSync('build', { recursive: true, force: true })\" && tsc -p tsconfig.build.json && node scripts/build-cli.js",
    "dev": "tsx watch scripts/start-server.ts",
    "parse-openapi": "tsx scripts/parse-openapi.ts",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build && npm run test && npm run typecheck"
  },
  "main": "./build/src/index.js",
  "types": "./build/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/src/index.d.ts",
      "default": "./build/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "bento-mcp": "bin/cli.mjs",
    "anytype-mcp": "bin/cli.mjs"
  },
  "files": [
    "bin/cli.mjs",
    "build/src",
    "LICENSE.md",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "axios": "1.13.6",
    "form-data": "4.0.5",
    "mustache": "4.2.0",
    "node-fetch": "3.3.2",
    "openapi-client-axios": "7.9.0",
    "openapi-schema-validator": "12.1.3",
    "openapi-types": "12.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.80.0",
    "@eslint/js": "9.39.2",
    "@types/json-schema": "7.0.15",
    "@types/mustache": "4.2.6",
    "@types/node": "25.5.0",
    "@types/which": "3.0.4",
    "@vitest/coverage-v8": "4.1.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "eslint": "9.39.2",
    "esbuild": "0.27.4",
    "openai": "6.32.0",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "description": "Official MCP server for Bento API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kimenzo/anytype-mcp.git"
  },
  "author": "Kimenzo",
  "bugs": {
    "url": "https://github.com/Kimenzo/anytype-mcp/issues"
  },
  "homepage": "https://github.com/Kimenzo/anytype-mcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
